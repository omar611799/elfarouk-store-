rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userRole() {
      return signedIn() && exists(userPath()) ? get(userPath()).data.role : null;
    }

    function isAdmin() {
      return signedIn() && userRole() == 'admin';
    }

    function isCustomer() {
      return signedIn() && userRole() == 'customer';
    }

    // Admin-only business collections.
    match /products/{id} {
      allow read, write: if isAdmin();
    }
    match /categories/{id} {
      allow read, write: if isAdmin();
    }
    match /suppliers/{id} {
      allow read, write: if isAdmin();
    }
    match /customers/{id} {
      allow read, write: if isAdmin();
    }
    match /invoices/{id} {
      allow read, write: if isAdmin();
    }
    match /transactions/{id} {
      allow read, write: if isAdmin();
    }
    match /expenses/{id} {
      allow read, write: if isAdmin();
    }
    match /quotations/{id} {
      allow read, write: if isAdmin();
    }
    match /users/{id} {
      // Users can read their own user document. Admin can manage all.
      allow create: if signedIn() && request.auth.uid == id;
      allow read: if isAdmin() || (signedIn() && request.auth.uid == id);
      allow update, delete: if isAdmin() || (signedIn() && request.auth.uid == id);
    }
    match /stockLogs/{id} {
      allow read, write: if isAdmin();
    }
    match /purchases/{id} {
      allow read, write: if isAdmin();
    }

    // Customer account profile:
    // - customer reads/writes only own account by uid
    // - admin can fully manage
    match /customerAccounts/{id} {
      allow create: if isCustomer() && request.resource.data.uid == request.auth.uid;
      allow read, update: if (isCustomer() && resource.data.uid == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Service bookings:
    // - admin full access
    // - customer sees/creates/updates only own booking docs
    match /serviceBookings/{id} {
      allow create: if isCustomer()
        && request.resource.data.customerAuthUid == request.auth.uid
        && request.resource.data.status == 'new'
        && request.resource.data.slotPrice == 50;

      allow read, update: if isAdmin()
        || (isCustomer() && resource.data.customerAuthUid == request.auth.uid);

      allow delete: if isAdmin();
    }

    // Service messages are scoped by booking ownership.
    match /serviceMessages/{id} {
      allow create: if isAdmin()
        || (isCustomer() && request.resource.data.customerAuthUid == request.auth.uid);

      allow read: if isAdmin()
        || (isCustomer() && resource.data.customerAuthUid == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    // Notifications:
    // - admin reads admin notifications
    // - customer reads own notifications
    match /notifications/{id} {
      // Allow both parties to create notifications scoped to their own UID.
      // Customer can only create admin notifications for their own booking.
      allow create: if isAdmin()
        || (isCustomer()
          && request.resource.data.audience == 'admin'
          && request.resource.data.customerAuthUid == request.auth.uid);
      allow read, update: if isAdmin()
        || (isCustomer() && resource.data.customerAuthUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Block everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
